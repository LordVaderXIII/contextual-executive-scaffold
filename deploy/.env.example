# Example values for disposable local/test compose only.
# Copy to .env if you override defaults (optional for scaffold).

DATABASE_URL=mysql+pymysql://ces_user:ces_test_password@db:3306/ces?charset=utf8mb4
SEED_ON_START=true

# Production (external MariaDB on Unraid) — not used by test compose db service:
